#!/bin/bash
# chezmoi:template:hash
# Runs whenever this script changes (add/remove a tool → re-runs automatically)
set -euo pipefail

echo "── Installing packages ────────────────────────────────────────────"

install_if_missing() {
  if ! command -v "$1" &>/dev/null; then
    echo "Installing $1..."
    eval "$2"
  else
    echo "✓ $1 already installed"
  fi
}

# ── Detect architecture ─────────────────────────────────────────────
ARCH="$(uname -m)"
case "$ARCH" in
  x86_64)  DEB_ARCH="amd64"; GH_ARCH="x86_64" ;;
  aarch64|arm64) DEB_ARCH="arm64"; GH_ARCH="arm64" ;;
  *) echo "Unsupported architecture: $ARCH"; exit 1 ;;
esac

# Helper: install latest .deb from a GitHub release
install_gh_deb() {
  local repo="$1" pattern="$2"
  local url
  url=$(curl -fsSL "https://api.github.com/repos/${repo}/releases/latest" \
    | grep -oP "\"browser_download_url\":\s*\"\K[^\"]*${pattern}[^\"]*\"" \
    | head -1 | tr -d '"')
  if [[ -n "$url" ]]; then
    local tmp="/tmp/$(basename "$url")"
    curl -fsSL -o "$tmp" "$url"
    sudo dpkg -i "$tmp"
    rm -f "$tmp"
  else
    echo "  ⚠ Could not find release for $repo matching $pattern"
  fi
}

# Helper: install latest tarball binary from a GitHub release
install_gh_binary() {
  local repo="$1" pattern="$2" binary_name="$3"
  local url
  url=$(curl -fsSL "https://api.github.com/repos/${repo}/releases/latest" \
    | grep -oP "\"browser_download_url\":\s*\"\K[^\"]*${pattern}[^\"]*\"" \
    | head -1 | tr -d '"')
  if [[ -n "$url" ]]; then
    local tmpdir="/tmp/${binary_name}_extract"
    rm -rf "$tmpdir" && mkdir -p "$tmpdir"
    curl -fsSL -o "$tmpdir/archive.tar.gz" "$url"
    tar xf "$tmpdir/archive.tar.gz" -C "$tmpdir"
    local bin
    bin=$(find "$tmpdir" -name "$binary_name" -type f -executable | head -1)
    if [[ -z "$bin" ]]; then
      bin=$(find "$tmpdir" -name "$binary_name" -type f | head -1)
    fi
    if [[ -n "$bin" ]]; then
      sudo install "$bin" /usr/local/bin/
    else
      echo "  ⚠ Could not find $binary_name binary in archive"
    fi
    rm -rf "$tmpdir"
  else
    echo "  ⚠ Could not find release for $repo matching $pattern"
  fi
}

{{ if eq .osid "darwin" -}}
# ══════════════════════════════════════════════════════════════════════
# macOS
# ══════════════════════════════════════════════════════════════════════
if ! command -v brew &>/dev/null; then
  echo "Installing Homebrew..."
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  eval "$(/opt/homebrew/bin/brew shellenv 2>/dev/null || /usr/local/bin/brew shellenv)"
fi

brew install \
  zsh vim neovim tmux \
  starship zoxide fzf ripgrep fd bat eza \
  git-delta lazygit gh \
  direnv jq yq curl wget \
  yazi ffmpeg sevenzip poppler imagemagick resvg w3m lynx

# Ensure Neovim 0.11+ (required by LazyVim)
NVIM_CURRENT="$(nvim --version 2>/dev/null | head -1 | grep -oE '[0-9]+\.[0-9]+' || echo "0.0")"
NVIM_REQUIRED="0.11"
if ! printf '%s\n' "$NVIM_REQUIRED" "$NVIM_CURRENT" | sort -V | head -1 | grep -qx "$NVIM_REQUIRED"; then
  echo "Upgrading Neovim to >= $NVIM_REQUIRED (LazyVim requirement)..."
  brew upgrade neovim || brew install neovim
fi

# Nerd Font
brew install --cask font-jetbrains-mono-nerd-font

{{ else if (or (eq .osid "linux") (eq .osid "wsl")) -}}
# ══════════════════════════════════════════════════════════════════════
# Linux / WSL
# ══════════════════════════════════════════════════════════════════════

if command -v apt-get &>/dev/null; then
  # ── apt base packages ──────────────────────────────────────────────
  sudo apt-get update -qq
  sudo apt-get install -y -qq \
    zsh vim tmux curl wget git jq unzip fontconfig build-essential \
    ripgrep bat fd-find fzf eza direnv \
    ffmpeg p7zip-full poppler-utils imagemagick w3m lynx

  # Symlink bat/fd — Ubuntu packages use different binary names
  [[ -x /usr/bin/batcat ]] && ! command -v bat &>/dev/null && sudo ln -sf /usr/bin/batcat /usr/local/bin/bat
  [[ -x /usr/bin/fdfind ]] && ! command -v fd &>/dev/null && sudo ln -sf /usr/bin/fdfind /usr/local/bin/fd

  # ── Neovim 0.11+ (required by LazyVim) ──────────────────────────────
  NVIM_REQUIRED="0.11"
  NVIM_CURRENT="$(nvim --version 2>/dev/null | head -1 | grep -oP '\d+\.\d+' || echo "0.0")"
  if ! printf '%s\n' "$NVIM_REQUIRED" "$NVIM_CURRENT" | sort -V | head -1 | grep -qx "$NVIM_REQUIRED"; then
    echo "Installing Neovim >= $NVIM_REQUIRED from GitHub releases..."
    NVIM_URL=$(curl -fsSL "https://api.github.com/repos/neovim/neovim/releases/latest" \
      | grep -oP "\"browser_download_url\":\s*\"\K[^\"]*nvim-linux-${GH_ARCH}\.tar\.gz\"" \
      | head -1 | tr -d '"')
    if [[ -n "$NVIM_URL" ]]; then
      curl -fsSL -o /tmp/nvim.tar.gz "$NVIM_URL"
      sudo rm -rf /opt/nvim
      sudo mkdir -p /opt/nvim
      sudo tar xf /tmp/nvim.tar.gz -C /opt/nvim --strip-components=1
      sudo ln -sf /opt/nvim/bin/nvim /usr/local/bin/nvim
      rm -f /tmp/nvim.tar.gz
      hash -r
      echo "✓ $(/opt/nvim/bin/nvim --version | head -1) installed to /opt/nvim"
    else
      echo "  ⚠ Could not download Neovim — install v0.11+ manually"
    fi
  else
    echo "✓ neovim $NVIM_CURRENT already meets >= $NVIM_REQUIRED"
  fi

  # ── Tools not in apt — install via official methods ────────────────
  install_if_missing starship \
    'curl -sS https://starship.rs/install.sh | sh -s -- -y'

  install_if_missing zoxide \
    'curl -sSfL https://raw.githubusercontent.com/ajeetdsouza/zoxide/main/install.sh | sh'

  install_if_missing delta \
    "install_gh_binary dandavison/delta 'delta-.*-${GH_ARCH}-unknown-linux-gnu\.tar\.gz' delta"

  install_if_missing lazygit \
    "install_gh_binary jesseduffield/lazygit 'linux_${GH_ARCH}\.tar\.gz' lazygit"

  install_if_missing yq \
    "curl -fsSLo /tmp/yq 'https://github.com/mikefarah/yq/releases/latest/download/yq_linux_${DEB_ARCH}' && sudo install /tmp/yq /usr/local/bin/yq"

  install_if_missing yazi \
    "install_gh_binary sxyazi/yazi 'yazi-${GH_ARCH}-unknown-linux-gnu\.zip' yazi"

  install_if_missing gh \
    '(type -p wget >/dev/null || sudo apt install wget -y) && sudo mkdir -p -m 755 /etc/apt/keyrings && wget -qO- https://cli.github.com/packages/githubcli-archive-keyring.gpg | sudo tee /etc/apt/keyrings/githubcli-archive-keyring.gpg > /dev/null && sudo chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" | sudo tee /etc/apt/sources.list.d/github-cli-stable.list > /dev/null && sudo apt update && sudo apt install gh -y'

elif command -v dnf &>/dev/null; then
  # ── dnf base packages ──────────────────────────────────────────────
  sudo dnf install -y \
    zsh vim tmux curl wget git jq unzip fontconfig \
    fzf ripgrep fd-find bat direnv gcc make eza \
    ffmpeg p7zip poppler-utils ImageMagick w3m lynx

  # ── Neovim 0.11+ (required by LazyVim) ──────────────────────────────
  NVIM_REQUIRED="0.11"
  NVIM_CURRENT="$(nvim --version 2>/dev/null | head -1 | grep -oP '\d+\.\d+' || echo "0.0")"
  if ! printf '%s\n' "$NVIM_REQUIRED" "$NVIM_CURRENT" | sort -V | head -1 | grep -qx "$NVIM_REQUIRED"; then
    echo "Installing Neovim >= $NVIM_REQUIRED from GitHub releases..."
    NVIM_URL=$(curl -fsSL "https://api.github.com/repos/neovim/neovim/releases/latest" \
      | grep -oP "\"browser_download_url\":\s*\"\K[^\"]*nvim-linux-${GH_ARCH}\.tar\.gz\"" \
      | head -1 | tr -d '"')
    if [[ -n "$NVIM_URL" ]]; then
      curl -fsSL -o /tmp/nvim.tar.gz "$NVIM_URL"
      sudo rm -rf /opt/nvim
      sudo mkdir -p /opt/nvim
      sudo tar xf /tmp/nvim.tar.gz -C /opt/nvim --strip-components=1
      sudo ln -sf /opt/nvim/bin/nvim /usr/local/bin/nvim
      rm -f /tmp/nvim.tar.gz
      hash -r
      echo "✓ $(/opt/nvim/bin/nvim --version | head -1) installed to /opt/nvim"
    else
      echo "  ⚠ Could not download Neovim — install v0.11+ manually"
    fi
  else
    echo "✓ neovim $NVIM_CURRENT already meets >= $NVIM_REQUIRED"
  fi

  install_if_missing starship \
    'curl -sS https://starship.rs/install.sh | sh -s -- -y'

  install_if_missing zoxide \
    'curl -sSfL https://raw.githubusercontent.com/ajeetdsouza/zoxide/main/install.sh | sh'

  install_if_missing lazygit \
    'sudo dnf copr enable atim/lazygit -y && sudo dnf install -y lazygit'

  install_if_missing gh \
    'sudo dnf install -y gh'

  install_if_missing delta \
    "install_gh_binary dandavison/delta 'delta-.*-${GH_ARCH}-unknown-linux-gnu' delta"

  install_if_missing yq \
    "curl -fsSLo /tmp/yq 'https://github.com/mikefarah/yq/releases/latest/download/yq_linux_${DEB_ARCH}' && sudo install /tmp/yq /usr/local/bin/yq"

  install_if_missing yazi \
    "install_gh_binary sxyazi/yazi 'yazi-${GH_ARCH}-unknown-linux' yazi"

elif command -v pacman &>/dev/null; then
  # ── Arch ───────────────────────────────────────────────────────────
  sudo pacman -Syu --noconfirm --needed \
    zsh vim neovim tmux \
    starship zoxide fzf ripgrep fd bat eza \
    git-delta lazygit github-cli \
    direnv jq yq curl wget base-devel \
    yazi ffmpeg p7zip poppler imagemagick resvg w3m lynx

  # ── Ensure Neovim 0.11+ (required by LazyVim) ──────────────────────
  NVIM_REQUIRED="0.11"
  NVIM_CURRENT="$(nvim --version 2>/dev/null | head -1 | grep -oP '\d+\.\d+' || echo "0.0")"
  if ! printf '%s\n' "$NVIM_REQUIRED" "$NVIM_CURRENT" | sort -V | head -1 | grep -qx "$NVIM_REQUIRED"; then
    echo "Upgrading Neovim to >= $NVIM_REQUIRED (LazyVim requirement)..."
    sudo pacman -Syu --noconfirm neovim
  fi
fi

# ── Nerd Font (all Linux/WSL) ────────────────────────────────────────
if ! fc-list | grep -qi "JetBrainsMono.*Nerd"; then
  echo "Installing JetBrainsMono Nerd Font..."
  FONT_DIR="$HOME/.local/share/fonts"
  mkdir -p "$FONT_DIR"
  FONT_URL=$(curl -fsSL "https://api.github.com/repos/ryanoasis/nerd-fonts/releases/latest" \
    | grep -oP '"browser_download_url":\s*"\K[^"]*JetBrainsMono\.tar\.xz"' \
    | head -1 | tr -d '"')
  if [[ -n "$FONT_URL" ]]; then
    curl -fsSL -o /tmp/nerd-font.tar.xz "$FONT_URL"
    tar xf /tmp/nerd-font.tar.xz -C "$FONT_DIR"
    fc-cache -f "$FONT_DIR"
    rm -f /tmp/nerd-font.tar.xz
    echo "✓ JetBrainsMono Nerd Font installed"
  else
    echo "  ⚠ Could not download Nerd Font — install manually"
  fi
fi

{{ end -}}

# ── Clean old nvim plugins if switching to LazyVim ───────────────────
NVIM_DATA="${XDG_DATA_HOME:-$HOME/.local/share}/nvim"
if [[ -d "$NVIM_DATA/lazy" ]] && [[ ! -d "$NVIM_DATA/lazy/LazyVim" ]]; then
  echo "Clearing old nvim plugin data for LazyVim migration..."
  rm -rf "$NVIM_DATA" "${XDG_STATE_HOME:-$HOME/.local/state}/nvim" "${XDG_CACHE_HOME:-$HOME/.cache}/nvim"
fi

# ── Set zsh as default shell ─────────────────────────────────────────
SHELL_CHANGED=false
if [[ "$SHELL" != */zsh ]]; then
  echo "Changing default shell to zsh..."
  chsh -s "$(command -v zsh)" || echo "  ⚠ Could not change shell — run: chsh -s $(command -v zsh)"
  SHELL_CHANGED=true
fi

# ── Post-install summary ────────────────────────────────────────────
echo ""
echo "✓ All packages installed"
echo ""
echo "── What to do next ──────────────────────────────────────────────"

NEEDS_RESTART=false

if [[ "$SHELL_CHANGED" == true ]]; then
  echo "  • Default shell changed to zsh — log out and back in, or run: exec zsh"
  NEEDS_RESTART=true
fi

{{ if (or (eq .osid "linux") (eq .osid "wsl")) -}}
if fc-list | grep -qi "JetBrainsMono.*Nerd" 2>/dev/null; then
  echo "  • Nerd Font was installed — restart your terminal to pick it up"
  NEEDS_RESTART=true
fi
{{ end -}}

if [[ "$NEEDS_RESTART" == false ]]; then
  echo "  • No restart needed — run 'exec zsh' to reload your shell config"
fi

echo "  • Run 'tmux' and press prefix+I to install tmux plugins"
echo "  • Run 'nvim' — LazyVim and plugins will auto-install on first launch"
echo "  • Run 'ya pack -a yazi-rs/flavors:catppuccin-mocha' to install the yazi theme"
